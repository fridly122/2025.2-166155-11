<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.SpinnerValueFactory.IntegerSpinnerValueFactory?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="640.0" prefWidth="900.0" style="-fx-background-color: #ecf0f1;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="itss.group11.frontend.screens.siteInventoryManage.SiteInventoryManageController">

    <children>
        <VBox spacing="15.0"
              style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);"
              AnchorPane.bottomAnchor="20.0"
              AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0"
              AnchorPane.topAnchor="20.0">

            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label text="CẬP NHẬT THÔNG TIN TỒN KHO SITE" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="20.0"/>
                            </font>
                        </Label>
                        <Button mnemonicParsing="false"
                                onAction="#handleRefresh"
                                text="Làm mới"
                                style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </children>
                </HBox>

                <VBox spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 6; -fx-padding: 15;">
                    <children>
                        <GridPane hgap="12.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="90.0" prefWidth="100.0"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="240.0" prefWidth="280.0"/>
                                <ColumnConstraints minWidth="90.0" prefWidth="100.0"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="240.0" prefWidth="280.0"/>
                            </columnConstraints>
                            <children>
                                <Label text="Site:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="cboSite"
                                          maxWidth="Infinity"
                                          prefWidth="280.0"
                                          promptText="Chọn site"
                                          GridPane.columnIndex="1"
                                          GridPane.rowIndex="0"/>

                                <Label text="Mặt hàng:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="cboMerchandise"
                                          maxWidth="Infinity"
                                          prefWidth="280.0"
                                          promptText="Chọn mặt hàng"
                                          GridPane.columnIndex="3"
                                          GridPane.rowIndex="0"/>

                                <Label text="Số lượng:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Spinner fx:id="spnInStockQuantity"
                                         editable="true"
                                         prefWidth="140.0"
                                         GridPane.columnIndex="1"
                                         GridPane.rowIndex="1">
                                    <valueFactory>
                                        <SpinnerValueFactory.IntegerSpinnerValueFactory min="0" max="1000000" initialValue="0"/>
                                    </valueFactory>
                                </Spinner>
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="btnUpdateInventory"
                                        mnemonicParsing="false"
                                        onAction="#handleUpdateInventory"
                                        prefHeight="38.0"
                                        text="Cập nhật tồn kho"
                                        style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Label fx:id="lblSelectedInventory"
                       maxWidth="Infinity"
                       text="Chưa chọn dòng tồn kho."
                       textFill="#34495e"
                       style="-fx-background-color: #eef5fb; -fx-background-radius: 6; -fx-padding: 10;">
                    <font>
                        <Font name="System Bold" size="13.0"/>
                    </font>
                </Label>

                <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="70.0" text="ID"/>
                        <TableColumn fx:id="colSiteCode" prefWidth="100.0" text="Mã site"/>
                        <TableColumn fx:id="colSiteName" prefWidth="180.0" text="Tên site"/>
                        <TableColumn fx:id="colMerchandiseCode" prefWidth="110.0" text="Mã hàng"/>
                        <TableColumn fx:id="colMerchandiseName" prefWidth="190.0" text="Tên hàng"/>
                        <TableColumn fx:id="colQuantity" prefWidth="90.0" text="Tồn kho"/>
                        <TableColumn fx:id="colUnit" prefWidth="80.0" text="Đơn vị"/>
                        <TableColumn fx:id="colStockStatus" prefWidth="120.0" text="Trạng thái"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
