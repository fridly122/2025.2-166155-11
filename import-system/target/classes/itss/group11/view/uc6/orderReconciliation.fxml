<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="640.0" prefWidth="900.0" style="-fx-background-color: #ecf0f1;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="itss.group11.controller.uc6.OrderReconciliationController">

    <children>
        <VBox spacing="15.0"
              style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);"
              AnchorPane.bottomAnchor="20.0"
              AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0"
              AnchorPane.topAnchor="20.0">

            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label text="ĐỐI SOÁT &amp; XÁC NHẬN NHẬP KHO" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="20.0"/>
                            </font>
                        </Label>
                        <Button mnemonicParsing="false"
                                onAction="#handleRefresh"
                                text="Làm mới"
                                style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </children>
                </HBox>

                <TableView fx:id="poTable" prefHeight="190.0" style="-fx-font-size: 14px;">
                    <columns>
                        <TableColumn fx:id="colOrderId" prefWidth="130.0" text="Mã PO"/>
                        <TableColumn fx:id="colRequestCode" prefWidth="140.0" text="Mã yêu cầu"/>
                        <TableColumn fx:id="colSite" prefWidth="260.0" text="Site nguồn"/>
                        <TableColumn fx:id="colStatus" prefWidth="130.0" text="Trạng thái"/>
                        <TableColumn fx:id="colCreatedDate" prefWidth="160.0" text="Ngày tạo"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label fx:id="lblSelectedPo" text="Chưa chọn đơn hàng" textFill="#34495e">
                            <font>
                                <Font name="System Bold" size="14.0"/>
                            </font>
                        </Label>

                        <TableView fx:id="lineTable" editable="true" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;">
                            <columns>
                                <TableColumn fx:id="colMerchandiseCode" prefWidth="120.0" text="Mã hàng"/>
                                <TableColumn fx:id="colMerchandiseName" prefWidth="260.0" text="Tên hàng"/>
                                <TableColumn fx:id="colOrderedQty" prefWidth="100.0" text="SL đặt"/>
                                <TableColumn fx:id="colReceivedQty" prefWidth="120.0" text="SL thực nhận"/>
                                <TableColumn fx:id="colDifferenceQty" prefWidth="120.0" text="Chênh lệch"/>
                                <TableColumn fx:id="colUnit" prefWidth="100.0" text="Đơn vị"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <VBox spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 6; -fx-padding: 15;">
                    <children>
                        <GridPane hgap="12.0" vgap="10.0">
                            <children>
                                <Label text="Người xác nhận:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="txtCreatedBy"
                                           promptText="VD: Nhân viên kho"
                                           GridPane.columnIndex="1"
                                           GridPane.rowIndex="0"/>

                                <Label text="Lý do sai lệch:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextArea fx:id="txtReason"
                                          prefRowCount="2"
                                          promptText="Nhập nếu có chênh lệch"
                                          GridPane.columnIndex="1"
                                          GridPane.rowIndex="1"/>

                                <Label text="Ghi chú:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <TextArea fx:id="txtNote"
                                          prefRowCount="2"
                                          promptText="Ghi chú thêm"
                                          GridPane.columnIndex="1"
                                          GridPane.rowIndex="2"/>
                            </children>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="btnConfirm"
                                        mnemonicParsing="false"
                                        onAction="#handleConfirmReconciliation"
                                        prefHeight="38.0"
                                        text="Xác nhận nhập kho"
                                        style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>

