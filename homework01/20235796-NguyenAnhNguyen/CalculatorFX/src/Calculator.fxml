<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox spacing="10" alignment="CENTER"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="CalculatorController">

    <TextField fx:id="firstNumber" promptText="Enter first number"/>

    <TextField fx:id="secondNumber" promptText="Enter second number"/>

    <TextField fx:id="resultField" promptText="Result" editable="false"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="+" onAction="#handleAdd"/>
        <Button text="-" onAction="#handleSub"/>
        <Button text="×" onAction="#handleMul"/>
        <Button text="÷" onAction="#handleDiv"/>
    </HBox>

</VBox>