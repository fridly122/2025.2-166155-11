<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER"
      spacing="15"
      prefHeight="400"
      prefWidth="400"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CalculatorController"
      style="-fx-background-color: #f4f6f8;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <children>

        <Label text="Simple Calculator">
            <font>
                <Font size="24"/>
            </font>
        </Label>

        <TextField fx:id="num1"
                   promptText="Enter first number"
                   prefWidth="250"
                   prefHeight="40"/>

        <TextField fx:id="num2"
                   promptText="Enter second number"
                   prefWidth="250"
                   prefHeight="40"/>

        <Button text="Add"
                onAction="#handleAdd"
                prefWidth="150"
                prefHeight="40"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;"/>

        <Label fx:id="result"
               text="Result:"
               style="-fx-font-size: 18px; -fx-text-fill: #333;"/>

    </children>

</VBox>